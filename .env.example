# Copy this file to .env.local and fill in real values.
# Next.js auto-loads .env.local. Standalone scripts (drizzle-kit, tsx)
# load it explicitly via the helpers in src/db/migrate.ts + drizzle.config.ts.

# ---------------- Database ----------------
# Use the Supabase "Transaction" pooled connection string (port 6543) for the app.
# Get it from: Supabase Dashboard -> Project Settings -> Database -> Connection string
# (the "Connection pooling" tab, transaction mode).
DATABASE_URL="postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require"

# Optional: direct (non-pooled) connection (port 5432) for long-running workers
# such as the future Telegram ingestion process. Not used yet.
# DATABASE_URL_DIRECT="postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require"

# ---------------- Supabase Auth ----------------
NEXT_PUBLIC_SUPABASE_URL="https://[project].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon-key]"

# Server-only key used for trusted admin operations (e.g. creating user profile rows).
# Never expose to the browser. Optional in Phase 1.
# SUPABASE_SERVICE_ROLE_KEY="[service-role-key]"

# ---------------- App ----------------
# Public base URL of the deployed app. Used for absolute URLs (OG, emails, etc.).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------------- LLM extraction ----------------
# Optional. When set, the ingestion pipeline uses Claude Haiku to read each
# scraped Telegram post and extract structured fields (price, rooms, area,
# district, etc.) instead of relying only on regex pattern matching.
# Falls back to the regex extractor automatically when this is unset or
# when an individual LLM call fails.
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# Optional override of the model used for extraction. Defaults to claude-haiku-4-5.
# ANTHROPIC_EXTRACTION_MODEL="claude-haiku-4-5"

# ---------------- Yandex.Direct (РСЯ) ads ----------------
# Optional. Each variable is a Yandex RTB block id, format
# "R-A-XXXXXXXX-N". Get them from https://partner.yandex.ru after
# your site is approved and you've created an RTB block per slot.
#
# When unset, the corresponding ad slot renders nothing — system
# works fine without them. Inlined into the client bundle at build
# time, so set them BEFORE you trigger a Railway deploy.
NEXT_PUBLIC_YANDEX_AD_FEED_BLOCK_ID=""
NEXT_PUBLIC_YANDEX_AD_DETAIL_BLOCK_ID=""

# ---------------- Google AdSense ----------------
# Optional. Three values required for AdSense to render:
#   - CLIENT_ID is your publisher id (format "ca-pub-XXXXXXXXXXXXXXXX")
#     from AdSense → Account → Account information → Publisher ID.
#   - FEED_SLOT / DETAIL_SLOT are per-ad-unit ids (format "1234567890")
#     from AdSense → Ads → By ad unit → Get code → look for
#     `data-ad-slot` in the snippet.
#
# When any of the three are unset, the Google ad slot renders nothing.
# Inlined into the client bundle at build time, so set them BEFORE you
# trigger a Railway deploy. Don't forget to also update public/ads.txt
# with your publisher id.
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_ADSENSE_FEED_SLOT=""
NEXT_PUBLIC_GOOGLE_ADSENSE_DETAIL_SLOT=""
